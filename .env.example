# RAG Hybrid Search - Environment Configuration
# Copy this file to .env and customize as needed

# ============================================================================
# API Configuration
# ============================================================================
API_TITLE=RAG Hybrid Search API
API_VERSION=1.0.0
DEBUG=false

# ============================================================================
# LLM Configuration (Ollama)
# ============================================================================
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=phi3.5:3.8b
LLM_TEMPERATURE=0.6
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
HYBRID_SEARCH_ALPHA=0.6

# Number of results to return
TOP_K_RESULTS=7

# ============================================================================
# Document Processing
# ============================================================================
# Characters per chunk
CHUNK_SIZE=800

# Overlap between chunks (preserves context)
CHUNK_OVERLAP=200

# Code-aware splitting (preserves YAML/code blocks)
USE_CODE_AWARE_SPLITTING=true

# Enhanced BM25 with technical tokenization
USE_ENHANCED_BM25=true

USE_DEVOPS_PROMPTS=true

USE_FAISS=true

# Use inverted index for BM25 (50-500x faster)
USE_INVERTED_BM25=true

# FAISS Configuration
FAISS_USE_HNSW=true
FAISS_M=32
FAISS_EF_CONSTRUCTION=200
FAISS_EF_SEARCH=50
